# Copy to `.env` and fill in.
APP_NAME="Leadway RxHub · Provider API"
ENVIRONMENT=local
API_PREFIX=/api/v1

# JWT
JWT_SECRET=replace-me-with-32+chars
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=8

# Postgres (Render connection string)
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/rxhub

# Prognosis (Provider-Login + future enrollee API)
PROGNOSIS_BASE_URL=https://prognosis-api.leadwayhealth.com
PROGNOSIS_API_KEY=

# Embedded session handoff (when the portal is iframed inside a parent app
# the provider already signed into). Empty = handoff disabled.
EMBED_SHARED_SECRET=

# WellaHealth
WELLAHEALTH_BASE_URL=https://staging.wellahealth.com/v1
WELLAHEALTH_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# WhatsApp bot + routed numbers
WHATSAPP_BOT_URL=https://leadway-whatsapp-bot.onrender.com/api
WHATSAPP_NUMBER_ACUTE_LAGOS=
WHATSAPP_NUMBER_CHRONIC=

# Anthropic (drug classification assist)
ANTHROPIC_API_KEY=

# CORS (comma separated, * for dev)
CORS_ORIGINS=*
