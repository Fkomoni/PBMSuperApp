# ──────────────────────────────────────────────────────────────────────
# Leadway RxHub · Environment Variables Template
# ──────────────────────────────────────────────────────────────────────
#
# HOW TO USE THIS FILE ON AZURE:
# ──────────────────────────────
# Do NOT upload this file to Azure. Instead, open the Azure Portal →
# App Service → Configuration → Application settings, and add each line
# below as a separate setting (NAME on the left, VALUE on the right).
# Azure injects them into the app as environment variables at runtime.
#
# For local development, copy this file to `.env` (drop `.example`),
# fill in real values, and the backend will load them automatically.
# Never commit the filled-in .env file.
# ──────────────────────────────────────────────────────────────────────


# ── App mode ──────────────────────────────────────────────────────────
ENVIRONMENT=production


# ── JWT signing secret ────────────────────────────────────────────────
# Any random string ≥ 32 characters. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_TTL_HOURS=8


# ── Database (Azure gives you this after creating PostgreSQL) ─────────
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://rxhubadmin:PASSWORD@rxhub-db-prod.postgres.database.azure.com:5432/rxhub


# ── CORS — which front-ends may call this API ─────────────────────────
# Comma-separated, no trailing slashes. Include both the RxHub portal
# and any parent site that embeds it via iframe/SSO.
CORS_ORIGINS=https://rxhub.leadwayhealth.com,https://providers.leadwayhealth.com


# ── Public URL of this backend (used in emails, logos, attachments) ───
PUBLIC_BASE_URL=https://rxhub-api-prod.azurewebsites.net


# ── Prognosis (Leadway HMO legacy API) ────────────────────────────────
PROGNOSIS_BASE_URL=https://prognosis-api.leadwayhealth.com
PROGNOSIS_USERNAME=REPLACE_WITH_SERVICE_ACCOUNT_USERNAME
PROGNOSIS_PASSWORD=REPLACE_WITH_SERVICE_ACCOUNT_PASSWORD
# Optional: verbatim Authorization header value if Prognosis uses a
# non-Basic scheme. Leave blank when USERNAME+PASSWORD are set.
PROGNOSIS_AUTH_HEADER=


# ── WellaHealth (acute partner pharmacy) ──────────────────────────────
WELLAHEALTH_BASE_URL=https://api.wellahealth.com
WELLAHEALTH_CLIENT_ID=REPLACE_WITH_WELLA_CLIENT_ID
WELLAHEALTH_CLIENT_SECRET=REPLACE_WITH_WELLA_CLIENT_SECRET
WELLAHEALTH_PARTNER_CODE=REPLACE_WITH_WELLA_PARTNER_CODE


# ── WhatsApp bot + routing numbers ────────────────────────────────────
WHATSAPP_BOT_URL=https://leadway-whatsapp-bot.onrender.com/api
WHATSAPP_API_KEY=REPLACE_WITH_WHATSAPP_BOT_API_KEY
WHATSAPP_NUMBER_ACUTE_HOURS_LAGOS=+2347011706864
WHATSAPP_NUMBER_LAGOS_NON_ACUTE=+234708340602
WHATSAPP_NUMBER_OUTSIDE_NON_ACUTE=+234818123382841


# ── Admin bootstrap (creates the first admin user on startup) ─────────
ADMIN_BOOTSTRAP_EMAIL=admin@leadwayhealth.com
ADMIN_BOOTSTRAP_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_BOOTSTRAP_NAME=Leadway Admin


# ── Parent-portal SSO shared secret ───────────────────────────────────
# Any random string. Share the SAME value with the developer of the
# existing Leadway provider portal so they can mint auto-login links.
EMBED_SHARED_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING


# ── Google Maps (address autocomplete) ────────────────────────────────
GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_API_KEY


# ── Redis (optional — makes logout survive restarts) ──────────────────
# Leave blank to use in-memory revocation.
REDIS_URL=


# ── Anthropic (optional — AI drug classification) ─────────────────────
ANTHROPIC_API_KEY=
