# Copy to `.env` and fill in.
APP_NAME="Leadway RxHub · Provider API"
ENVIRONMENT=local
API_PREFIX=/api/v1

# JWT (portal sessions) — leave JWT_SECRET blank in local dev (we auto-gen
# a per-process random secret); MUST be set to a 32+ char value in prod.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=8
JWT_ISSUER=rxhub-provider-api
JWT_AUDIENCE=rxhub-provider-portal

# Postgres (Render connection string)
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/rxhub

# Prognosis — service account for member verify + ProviderLogIn proxy.
# Default auth is Basic(user:pass); if Prognosis wants a different scheme,
# set PROGNOSIS_AUTH_HEADER to the full header value (e.g. "Bearer eyJ…")
# and leave USERNAME/PASSWORD blank.
PROGNOSIS_BASE_URL=https://prognosis-api.leadwayhealth.com
PROGNOSIS_USERNAME=
PROGNOSIS_PASSWORD=
PROGNOSIS_AUTH_HEADER=

# WellaHealth — Basic auth (client_id:client_secret) + Partner-Code header
WELLAHEALTH_BASE_URL=https://api.wellahealth.com
WELLAHEALTH_CLIENT_ID=
WELLAHEALTH_CLIENT_SECRET=
WELLAHEALTH_PARTNER_CODE=

# Google Maps
GOOGLE_MAPS_API_KEY=

# WhatsApp bot + routed numbers
WHATSAPP_BOT_URL=https://leadway-whatsapp-bot.onrender.com/api
WHATSAPP_NUMBER_ACUTE_LAGOS=
WHATSAPP_NUMBER_CHRONIC=

# Anthropic (AI drug classification)
ANTHROPIC_API_KEY=

# Embedded session handoff (iframe / deep-link from a parent app the provider
# already signed into). Empty = handoff disabled.
EMBED_SHARED_SECRET=

# CORS (comma separated explicit origins, e.g. "http://localhost:5173").
# Wildcard "*" is accepted in local/dev but refused in production.
CORS_ORIGINS=http://localhost:5173
